---
import {
    BACKGROUND_COLOR,
    BODY_TEXT,
    PARAGRAPH_TEXT,
    PRIMARY_COLOR,
} from "../assets/constants.astro";

import { db } from "../db/firebase";

// ── Fetch bio document from portfolio collection ──────────────────────────────
const snap = await db.collection("portfolio").doc("bio").get();
const bio = snap.data();

// ── Destructure with safe fallbacks ──────────────────────────────────────────
const {
    name = "RISHIKESH K",
    description = "",
    skills = [],
    github = "",
    linkedIn = "",
    instagram = "",
    x = "",
    youtube = "",
    resume = "",
    email = "",
    age = 18,
    liveApps = 1,
    projects = "",
    downloads = "",
} = bio ?? {};
---

<section class="px-6 md:px-12 py-20 about-section" id="about">
    <!-- Section Label -->
    <div class="flex items-center gap-4 mb-10 about-label">
        <p class="text-gray-800 text-sm font-mono">01</p>
        <p
            class="text-sm font-mono tracking-[0.3em]"
            style={`color:${PRIMARY_COLOR}`}
        >
            ABOUT
        </p>
        <div class="w-20 h-[1px] bg-gray-800 label-line"></div>
    </div>

    <!-- Headline -->
    <h1
        class="text-[10vw] md:text-[7vw] font-medium leading-[0.9] about-headline"
    >
        <span class="headline-word block">BUILDING</span>
        <span class="headline-word block">THINGS</span>
        <span class="headline-word block">
            THAT
            <span style={`color:${PRIMARY_COLOR}`}> WORK</span>
        </span>
    </h1>

    <!-- Paragraphs -->
    <p
        class="text-sm text-gray-700 mt-7 about-para"
        style={`font-family:${BODY_TEXT}`}
    >
        I'm a
        <span class="text-sm font-black text-white pl-1 pr-1">
            self-taught Flutter developer
        </span>
        from Kerala, India. I don't just follow tutorials — I build real products,
        solve real problems, and ship them to real users.
    </p>

    <p
        class="text-sm text-gray-700 mt-7 about-para"
        style={`font-family:${BODY_TEXT}`}
    >
        My focus is
        <span class="text-sm font-black text-white pl-1 pr-1">
            {skills.join(", ")}
        </span>
        and writing code that's easy to maintain, extend, and defend in a code review.
    </p>

    <p
        class="text-sm text-gray-700 mt-7 about-para"
        style={`font-family:${BODY_TEXT}`}
    >
        Currently looking for my first engineering role where I can contribute
        to a real team and keep growing fast.
    </p>

    <!-- Stats — all driven by Firestore now -->
    <div class="flex items-start mt-20 gap-4">
        <!-- Live Apps -->
        <div class="flex flex-col gap-1 stat-block">
            <h1
                class="text-[5vh] font-black leading-none stat-number"
                style={`color:${PRIMARY_COLOR}`}
                data-target={liveApps}
            >
                0
            </h1>
            <span
                class="text-[1.3vh] font-mono tracking-[0.2em] text-gray-600 uppercase"
            >
                LIVE APP
            </span>
        </div>

        <!-- Projects -->
        <div class="flex flex-col gap-1 stat-block">
            <h1
                class="text-[5vh] font-black leading-none stat-number"
                style={`color:${PRIMARY_COLOR}`}
                data-target={projects}
                data-suffix="+"
            >
                0
            </h1>
            <span
                class="text-[1.3vh] font-mono tracking-[0.2em] text-gray-600 uppercase"
            >
                PROJECTS
            </span>
        </div>

        <!-- Downloads -->
        <div class="flex flex-col gap-1 stat-block">
            <h1
                class="text-[5vh] font-black leading-none stat-number"
                style={`color:${PRIMARY_COLOR}`}
                data-target={downloads}
                data-suffix="+"
            >
                0
            </h1>
            <span
                class="text-[1.3vh] font-mono tracking-[0.2em] text-gray-600 uppercase"
            >
                DOWNLOADS
            </span>
        </div>
    </div>
</section>

<style>
    /* ============================================
       BASE STATES — everything starts hidden
       IntersectionObserver adds .visible class
    ============================================ */

    /* Label row */
    .about-label {
        opacity: 0;
        transform: translateY(12px);
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
    }

    /* Label line grows in */
    .label-line {
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
    }

    /* Each headline word slides up */
    .headline-word {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        display: block;
    }

    /* Paragraphs fade + slide */
    .about-para {
        opacity: 0;
        transform: translateY(16px);
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
    }

    /* Stat blocks slide up */
    .stat-block {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
    }

    /* ============================================
       VISIBLE STATES — added by IntersectionObserver
    ============================================ */
    .about-label.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .about-label.visible .label-line {
        transform: scaleX(1);
    }

    .headline-word.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .about-para.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .stat-block.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* ============================================
       STAT NUMBER — count-up feel
    ============================================ */
    .stat-number {
        transition: color 0.3s ease;
        font-variant-numeric: tabular-nums;
    }

    /* ============================================
       REDUCED MOTION
    ============================================ */
    @media (prefers-reduced-motion: reduce) {
        .about-label,
        .label-line,
        .headline-word,
        .about-para,
        .stat-block {
            opacity: 1 !important;
            transform: none !important;
            transition: none !important;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // ============================================
        // INTERSECTION OBSERVER
        // Watches each animated element individually
        // so they trigger as they enter the viewport
        // ============================================
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("visible");
                        // Unobserve after animating — runs once
                        observer.unobserve(entry.target);
                    }
                });
            },
            {
                // Trigger when 15% of element is visible
                threshold: 0.15,
            },
        );

        // -- Label
        const label = document.querySelector(".about-label");
        if (label) observer.observe(label);

        // -- Headline words — stagger via delay
        const words = document.querySelectorAll(".headline-word");
        words.forEach((word, i) => {
            (word as HTMLElement).style.transitionDelay = `${0.1 + i * 0.12}s`;
            observer.observe(word);
        });

        // -- Paragraphs — stagger
        const paras = document.querySelectorAll(".about-para");
        paras.forEach((para, i) => {
            (para as HTMLElement).style.transitionDelay = `${0.1 + i * 0.12}s`;
            observer.observe(para);
        });

        // -- Stat blocks — stagger
        const stats = document.querySelectorAll(".stat-block");
        stats.forEach((stat, i) => {
            (stat as HTMLElement).style.transitionDelay = `${0.1 + i * 0.1}s`;
            observer.observe(stat);
        });

        // ============================================
        // COUNT-UP ANIMATION
        // Numbers count up from 0 when stats enter view
        // Feels alive — a static number feels dead
        // ============================================
        const countUpObserver = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (!entry.isIntersecting) return;

                    const el = entry.target as HTMLElement;
                    const target = parseInt(el.dataset.target || "0", 10);
                    const suffix = el.dataset.suffix || "";
                    const duration = 1200; // ms
                    const startTime = performance.now();

                    const tick = (now: number) => {
                        const elapsed = now - startTime;
                        const progress = Math.min(elapsed / duration, 1);

                        // Ease out cubic — decelerates at end
                        const eased = 1 - Math.pow(1 - progress, 3);
                        const current = Math.floor(eased * target);

                        el.textContent =
                            current + (progress === 1 ? suffix : "");

                        if (progress < 1) {
                            requestAnimationFrame(tick);
                        }
                    };

                    requestAnimationFrame(tick);
                    countUpObserver.unobserve(el);
                });
            },
            { threshold: 0.5 },
        );

        document.querySelectorAll(".stat-number").forEach((el) => {
            countUpObserver.observe(el);
        });
    });
</script>
