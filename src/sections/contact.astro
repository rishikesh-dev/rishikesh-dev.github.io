---
import "../styles/contact.css";
---

<!-- CONTACT -->
<section id="contact" class="p-5">
    <div class="section-label">
        <span>04</span> Contact
    </div>
    <div class="contact-inner">
        <h2 class="contact-headline">LET'S<br /><span>TALK.</span></h2>
        <p class="contact-desc" style="font-family: var(--font-body);">
            I'm actively looking for my first engineering role. If you're
            building something with Flutter or need a developer who ships real
            products — reach out.
        </p>
        <div class="contact-links">
            <a href="mailto:rishikeshk.richi@gmail.com" class="btn-primary"
                >Send Email</a
            >
            <a
                href="https://linkedin.com/in/rishikesh-k-richi"
                class="contact-email"
                target="_blank">LinkedIn</a
            >
            <a
                href="https://github.com/rishikesh-dev"
                class="contact-email"
                target="_blank">GitHub</a
            >
        </div>
    </div>
</section>
