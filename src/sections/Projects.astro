---
import "../styles/project.css";
import { db } from "../db/firebase.ts";

type Project = {
    id: string;
    title: string;
    description: string;
    image: string;
    techStack: string[];
    tag: string;
    playStoreUrl: string;
    githubUrl: string;
    buyNow: string;
    story: string;
    highlight: string;
    decisions: string[];
};

const snap = await db.collection("projects").get();

const projects: Project[] = snap.docs.map((doc) => {
    const data = doc.data();
    return {
        id: doc.id,
        title: data.title ?? "",
        description: data.description ?? "",
        image: data.image ?? "",
        techStack: Array.isArray(data.techStack)
            ? data.techStack
            : (data.techStack ?? "")
                  .split(",")
                  .map((s: string) => s.trim())
                  .filter(Boolean),
        tag: data.tag ?? "",
        playStoreUrl: data.playStoreUrl ?? "",
        githubUrl: data.githubUrl ?? "",
        buyNow: data.buyNow ?? "",
        story: data.story ?? "",
        highlight: data.highlight ?? "",
        decisions: Array.isArray(data.decisions) ? data.decisions : [],
    };
});

const projectMap = Object.fromEntries(projects.map((p) => [p.id, p]));
---

<section id="projects" class="p-5">
    <div class="section-label">
        <span>02</span> Projects
    </div>

    <div class="projects-grid">
        {
            projects.map((p) => (
                <div class="project-card" data-id={p.id}>
                    {p.tag && <div class="project-tag">{p.tag}</div>}
                    {p.playStoreUrl && (
                        <div class="project-tag">
                            Featured · Live on Play Store
                        </div>
                    )}

                    <div class="project-name">{p.title}</div>
                    <p class="project-desc">{p.description}</p>
                    <div class="project-tech">
                        {p.techStack.map((t: string) => (
                            <span class="tech-pill">{t}</span>
                        ))}
                    </div>

                    <div class="view-details">View Case Study</div>
                </div>
            ))
        }
    </div>
</section>

<!-- Bottom Sheet -->
<div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modal">
        <button class="modal-close" id="modalCloseBtn"> ESC / CLOSE </button>

        <div class="modal-tag" id="modalTag"></div>
        <div class="modal-title" id="modalTitle"></div>

        <div class="modal-grid">
            <div class="modal-story">
                <h3>The Problem & Solution</h3>

                <p id="modalStory" class="modal-story"></p>
                <div class="modal-highlight" id="modalHighlight"></div>
                <div class="modal-desc" id="modalDesc"></div>
            </div>

            <div class="modal-sidebar">
                <div class="modal-sidebar-block">
                    <h4>Tech Stack</h4>
                    <ul id="modalTech" class="modal-tech-list"></ul>
                </div>

                <div class="modal-sidebar-block">
                    <h4>Key Decisions</h4>
                    <ul id="modalDecisions" class="modal-tech-list"></ul>
                </div>
            </div>
        </div>

        <div class="modal-actions" id="modalActions"></div>
    </div>
</div><script define:vars={{ projectMap }}>
    function openModal(id) {
        const p = projectMap[id];
        if (!p) return;

        // Basic content
        document.getElementById("modalTag").textContent = p.tag ?? "";
        document.getElementById("modalTitle").textContent = p.title ?? "";
        document.getElementById("modalStory").innerHTML = p.story ?? "";
        document.getElementById("modalDesc").innerHTML = p.description ?? "";
        document.getElementById("modalHighlight").innerHTML = p.highlight ?? "";

        // Tech
        document.getElementById("modalTech").innerHTML = (p.techStack ?? [])
            .map((t) => `<li>${t}</li>`)
            .join("");

        // Decisions
        document.getElementById("modalDecisions").innerHTML = (
            p.decisions ?? []
        )
            .map((d) => `<li>${d}</li>`)
            .join("");

        // Actions
        const actions = [];

        if (p.playStoreUrl) {
            actions.push(
                `<a href="${p.playStoreUrl}" target="_blank" class="btn-primary">Play Store</a>`,
            );
        }

        if (p.githubUrl) {
            actions.push(
                `<a href="${p.githubUrl}" target="_blank" class="btn-primary">GitHub</a>`,
            );
        }
        if (p.buyNow) {
            actions.push(
                `<a href="${p.buyNow}" target="_blank" class="btn-primary">Get Now</a>`,
            );
        }

        document.getElementById("modalActions").innerHTML = actions.join("");

        // Open modal
        document.getElementById("modalOverlay").classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeModal() {
        document.getElementById("modalOverlay")?.classList.remove("active");
        document.body.style.overflow = "";
    }

    window.addEventListener("DOMContentLoaded", () => {
        const overlay = document.getElementById("modalOverlay");
        const closeBtn = document.getElementById("modalCloseBtn");

        // Close button (SAFE)
        if (closeBtn) {
            closeBtn.addEventListener("click", closeModal);
        }

        // Overlay click
        if (overlay) {
            overlay.addEventListener("click", (e) => {
                if (e.target === overlay) closeModal();
            });
        }

        // ESC key
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeModal();
        });

        // Card click (SAFE delegation)
        document.addEventListener("click", (e) => {
            const card = e.target.closest(".project-card");

            // Prevent clicks inside modal from triggering this
            if (!card || overlay.contains(e.target)) return;

            openModal(card.dataset.id);
        });
    });
</script>
