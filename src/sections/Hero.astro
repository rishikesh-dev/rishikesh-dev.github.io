---
import { PRIMARY_COLOR } from "../assets/constants.astro";
---

<section
    class="min-h-screen flex flex-col justify-end px-6 md:px-12 pb-20 relative hero-section"
>
    <!-- Background Text -->
    <div
        class="absolute right-0 top-1/2 -translate-y-1/2
              text-[25vw] font-black text-[#333]
              pointer-events-none select-none hero-bg-text"
    >
        RK
    </div>

    <!-- Tag -->
    <div class="flex items-center gap-3 mb-4 hero-tag">
        <div class="w-8 h-[1px] bg-[#C8FF00] tag-line"></div>
        <p
            class="text-[#C8FF00] uppercase tracking-[0.3em] text-xs font-mono tag-text"
        >
            Flutter Developer · India
        </p>
    </div>

    <!-- Headline -->
    <h1
        class="text-[15vw] md:text-[130px] leading-[0.9] font-black tracking-tight"
    >
        <span class="hero-word block">RISHI</span>
        <span class="hero-word block text-[#C8FF00]">KESH K</span>
    </h1>

    <!-- Bottom -->
    <div
        class="flex flex-col md:flex-col md:justify-between mt-10 gap-8 xl:flex-col"
    >
        <p
            class="text-gray-500 max-w-sm text-sm leading-relaxed hero-para"
            style="font-family: 'Epilogue';"
        >
            Self-taught Flutter developer building real, shipped products. Clean
            Architecture. Bloc. RevenueCat. One app on the Play Store.
        </p>

        <div class="flex gap-4 hero-actions">
            <a
                href="#projects"
                class="bg-[#C8FF00] text-black px-6 py-3 text-xs uppercase tracking-widest font-mono hero-btn-primary"
            >
                View Work
            </a>

            <a
                href="https://github.com/rishikesh-dev"
                class="border border-[#2a2a2a] px-6 py-3 text-xs uppercase tracking-widest font-mono text-white hero-btn-secondary"
            >
                GitHub
            </a>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[10px] tracking-widest text-gray-500 font-mono hero-scroll"
    >
        scroll
    </div>
</section>

<style>
    /* ============================================
       KEYFRAMES
    ============================================ */

    /* Big text drifts in from right */
    @keyframes bgTextDrift {
        from {
            opacity: 0;
            transform: translateY(-50%) translateX(60px);
        }
        to {
            opacity: 1;
            transform: translateY(-50%) translateX(0);
        }
    }

    /* Line grows left to right */
    @keyframes lineGrow {
        from {
            transform: scaleX(0);
        }
        to {
            transform: scaleX(1);
        }
    }

    /* Tag text reveals from left */
    @keyframes tagReveal {
        from {
            opacity: 0;
            transform: translateX(-10px);
            letter-spacing: 0.5em;
        }
        to {
            opacity: 1;
            transform: translateX(0);
            letter-spacing: 0.3em;
        }
    }

    /* Headline words slam down from above */
    @keyframes wordSlam {
        from {
            opacity: 0;
            transform: translateY(-60px) skewY(-3deg);
        }
        to {
            opacity: 1;
            transform: translateY(0) skewY(0deg);
        }
    }

    /* Paragraph fades up softly */
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Buttons slide up with stagger */
    @keyframes btnReveal {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Scroll indicator bobs up and down */
    @keyframes scrollBob {
        0%,
        100% {
            transform: translateX(-50%) translateY(0);
            opacity: 0.5;
        }
        50% {
            transform: translateX(-50%) translateY(6px);
            opacity: 1;
        }
    }

    /* Primary button shimmer on load */
    @keyframes shimmer {
        0% {
            background-position: -200% center;
        }
        100% {
            background-position: 200% center;
        }
    }

    /* ============================================
       BACKGROUND TEXT
       Drifts in slowly — depth layer
    ============================================ */
    .hero-bg-text {
        opacity: 0;
        animation: bgTextDrift 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
    }

    /* ============================================
       TAG LINE + TEXT
    ============================================ */
    .tag-line {
        transform-origin: left;
        transform: scaleX(0);
        animation: lineGrow 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    .tag-text {
        opacity: 0;
        animation: tagReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    }

    /* ============================================
       HEADLINE WORDS
       First word slams in, second follows
    ============================================ */
    .hero-word {
        opacity: 0;
        animation: wordSlam 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .hero-word:nth-child(1) {
        animation-delay: 0.7s;
    }

    .hero-word:nth-child(2) {
        animation-delay: 0.85s;
    }

    /* ============================================
       PARAGRAPH
    ============================================ */
    .hero-para {
        opacity: 0;
        animation: fadeUp 0.6s ease 1.1s forwards;
    }

    /* ============================================
       BUTTONS
    ============================================ */
    .hero-btn-primary {
        opacity: 0;
        animation: btnReveal 0.5s ease 1.2s forwards;
        position: relative;
        overflow: hidden;
        transition:
            background 0.2s ease,
            transform 0.2s ease;
    }

    /* Shimmer runs once after button appears */
    .hero-btn-primary::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            transparent 40%,
            rgba(255, 255, 255, 0.25) 50%,
            transparent 60%
        );
        background-size: 200% auto;
        animation: shimmer 0.8s linear 1.8s forwards;
    }

    .hero-btn-primary:hover {
        transform: translateY(-2px);
    }

    .hero-btn-primary:active {
        transform: translateY(0);
    }

    .hero-btn-secondary {
        opacity: 0;
        animation: btnReveal 0.5s ease 1.3s forwards;
        transition:
            border-color 0.2s ease,
            transform 0.2s ease;
    }

    .hero-btn-secondary:hover {
        transform: translateY(-2px);
    }

    .hero-btn-secondary:active {
        transform: translateY(0);
    }

    /* ============================================
       SCROLL INDICATOR
       Bobs forever — draws eye downward
    ============================================ */
    .hero-scroll {
        opacity: 0;
        /* Fade in first, then bob */
        animation:
            fadeUp 0.5s ease 1.6s forwards,
            scrollBob 2s ease-in-out 2.2s infinite;
    }

    /* ============================================
       REDUCED MOTION — ACCESSIBILITY
    ============================================ */
    @media (prefers-reduced-motion: reduce) {
        .hero-bg-text,
        .tag-line,
        .tag-text,
        .hero-word,
        .hero-para,
        .hero-btn-primary,
        .hero-btn-primary::after,
        .hero-btn-secondary,
        .hero-scroll {
            opacity: 1 !important;
            transform: none !important;
            animation: none !important;
            letter-spacing: inherit !important;
        }

        .tag-line {
            transform: scaleX(1) !important;
        }
    }
</style>
