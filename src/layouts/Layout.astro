---
import { BACKGROUND_COLOR } from "../assets/constants.astro";
---

<!doctype html>
<html lang="en" class="bg-black">
	<head>
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Epilogue:wght@400;600&family=IBM+Plex+Mono&display=swap"
			rel="stylesheet"
		/>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body
		class="bg-black text-white min-h-screen"
		style={`background-color: ${BACKGROUND_COLOR}; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");`}
	>
		<div class="page-wrapper">
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		font-family: "Bebas Neue", "Epilogue", "IBM Plex Mono";
		margin: 0;
	}

	/* Page load fade in */
	.page-wrapper {
		animation: fadeIn 0.6s ease-in-out forwards;
	}

	/* Noise texture animation */
	body {
		background-size: 200px 200px;
		animation: noiseShift 8s steps(2) infinite;
	}

	/* ----------------------- */
	/*     Keyframe Animations  */
	/* ----------------------- */

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes noiseShift {
		0% {
			background-position: 0% 0%;
		}
		25% {
			background-position: 50% 50%;
		}
		50% {
			background-position: 100% 0%;
		}
		75% {
			background-position: 50% 100%;
		}
		100% {
			background-position: 0% 0%;
		}
	}

	/* -------------------------------- */
	/*  Global reusable animation classes */
	/* -------------------------------- */

	/* Slide up - add class="animate-slide-up" to any element */
	:global(.animate-slide-up) {
		opacity: 0;
		animation: slideUp 0.6s ease forwards;
	}

	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Stagger children - add class="stagger-children" to parent */
	:global(.stagger-children > *) {
		opacity: 0;
		animation: slideUp 0.5s ease forwards;
	}

	:global(.stagger-children > *:nth-child(1)) {
		animation-delay: 0.1s;
	}
	:global(.stagger-children > *:nth-child(2)) {
		animation-delay: 0.2s;
	}
	:global(.stagger-children > *:nth-child(3)) {
		animation-delay: 0.3s;
	}
	:global(.stagger-children > *:nth-child(4)) {
		animation-delay: 0.4s;
	}
	:global(.stagger-children > *:nth-child(5)) {
		animation-delay: 0.5s;
	}

	/* Pulse glow - add class="animate-glow" to any element */
	:global(.animate-glow) {
		animation: glow 2s ease-in-out infinite alternate;
	}

	@keyframes glow {
		from {
			text-shadow:
				0 0 5px #fff,
				0 0 10px #fff;
		}
		to {
			text-shadow:
				0 0 20px #fff,
				0 0 40px #aaa;
		}
	}

	/* Scroll-triggered fade - add class="animate-on-scroll" to any element */
	:global(.animate-on-scroll) {
		opacity: 0;
		transform: translateY(20px);
		transition:
			opacity 0.6s ease,
			transform 0.6s ease;
	}

	:global(.animate-on-scroll.visible) {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<!-- Scroll animation observer -->
<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("visible");
				}
			});
		},
		{ threshold: 0.1 },
	);

	document.querySelectorAll(".animate-on-scroll").forEach((el) => {
		observer.observe(el);
	});
</script>
