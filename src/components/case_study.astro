---
import { BODY_TEXT } from "../assets/constants.astro";
import { db } from "../db/firebase.ts";

const snap = await db.collection("projects").get();
const projects = snap.docs.map((doc) => {
    const data = doc.data();
    return {
        id: doc.id,
        title: data.title ?? "",
        description: data.description ?? "",
        image: data.image ?? "",
        techStack: Array.isArray(data.techStack)
            ? data.techStack
            : (data.techStack ?? "")
                  .split(",")
                  .map((s: string) => s.trim())
                  .filter(Boolean),

        tag: data.tag ?? "",
        playStoreUrl: data.playStoreUrl ?? "",
        githubUrl: data.githubUrl ?? "",

        // 🔥 ADD THESE
        story: data.story ?? "",
        highlight: data.highlight ?? "",
        decisions: data.decisions ?? [],
    };
});
---

<!-- CASE STUDY MODAL -->
<div
    id="caseStudyOverlay"
    class="fixed inset-0 z-50 hidden items-center justify-center p-6"
    style="background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);"
    onclick="handleOverlayClick(event)"
>
    <div
        id="caseStudyModal"
        class="relative w-full max-w-4xl max-h-[90vh] overflow-y-auto"
        style="background: #0f0f0f; border: 1px solid #2a2a2a; border-top: 2px solid #C8FF00; padding: 56px;"
    >
        <button
            onclick="closeCaseStudy()"
            class="absolute top-6 right-6 text-[11px] tracking-widest uppercase transition-colors duration-200"
            style={`font-family: ${BODY_TEXT}; color: #555;`}
            onmouseover="this.style.color='#C8FF00'"
            onmouseout="this.style.color='#555'"
        >
            ESC / CLOSE
        </button>

        <!-- Tag -->
        <div
            id="csTag"
            class="text-[10px] tracking-[0.2em] uppercase mb-4"
            style={`font-family: ${BODY_TEXT}; color: #C8FF00;`}
        >
        </div>

        <!-- Title -->
        <div
            id="csTitle"
            class="text-[56px] leading-none tracking-wide mb-10"
            style="font-family: 'Bebas Neue', sans-serif; color: #F0F0F0;"
        >
        </div>

        <!-- Grid: story + sidebar -->
        <div class="grid gap-12" style="grid-template-columns: 1fr 320px;">
            <div>
                <h3
                    class="text-[11px] tracking-[0.2em] uppercase mb-6"
                    style={`font-family: ${BODY_TEXT}; color: #555;`}
                >
                    The Problem &amp; Solution
                </h3>
                <div
                    id="csStory"
                    class="text-[14px] leading-relaxed space-y-4"
                    style={`font-family: ${BODY_TEXT}; color: #555; font-weight: 300;`}
                >
                </div>
                <!-- Highlight box -->
                <div
                    id="csHighlight"
                    class="mt-8 p-6 text-[13px] leading-relaxed"
                    style={`font-family: ${BODY_TEXT}; color: #F0F0F0; border-left: 3px solid #C8FF00; background: #161616;`}
                >
                </div>
            </div>

            <div class="flex flex-col gap-8">
                <!-- Tech stack -->
                <div>
                    <h4
                        class="text-[10px] tracking-[0.2em] uppercase mb-4 pb-3"
                        style={`font-family: ${BODY_TEXT}; color: #C8FF00; border-bottom: 1px solid #2a2a2a;`}
                    >
                        Tech Stack
                    </h4>
                    <ul id="csTech" class="flex flex-col gap-2"></ul>
                </div>
                <!-- Key decisions -->
                <div>
                    <h4
                        class="text-[10px] tracking-[0.2em] uppercase mb-4 pb-3"
                        style={`font-family: ${BODY_TEXT}; color: #C8FF00; border-bottom: 1px solid #2a2a2a;`}
                    >
                        Key Decisions
                    </h4>
                    <ul id="csDecisions" class="flex flex-col gap-2"></ul>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div
            id="csActions"
            class="flex gap-4 mt-12 pt-8"
            style="border-top: 1px solid #1e1e1e;"
        >
        </div>
    </div>
</div>

<style>
    #caseStudyOverlay.open {
        display: flex;
    }
    #caseStudyModal {
        animation: slideUp 0.3s ease;
    }
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    #csTech li,
    #csDecisions li {
        font-size: 13px;
        color: #555;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 300;
        transition: color 0.2s;
    }
    #csTech li:hover,
    #csDecisions li:hover {
        color: #f0f0f0;
    }
    #csTech li::before,
    #csDecisions li::before {
        content: "";
        width: 4px;
        height: 4px;
        background: #c8ff00;
        flex-shrink: 0;
    }
</style>

<script
    define:vars={{
        caseStudies: Object.fromEntries(
            projects.map((p) => [
                p.id,
                {
                    tag: p.tag,
                    title: p.title,
                    story: p.story,
                    highlight: p.highlight,
                    techStack: p.techStack,
                    decisions: p.decisions,
                    playStoreUrl: p.playStoreUrl,
                },
            ]),
        ),
    }}
>
    window.openCaseStudy = function (id) {
        const p = caseStudies[id];
        if (!p) return;

        document.getElementById("csTag").textContent = p.tag;
        document.getElementById("csTitle").textContent = p.title;
        document.getElementById("csStory").innerHTML = p.story;
        document.getElementById("csHighlight").innerHTML = p.highlight;

        const monoStyle = `font-family: 'IBM Plex Mono', monospace`;

        document.getElementById("csTech").innerHTML = p.techStack
            .map((t) => `<li style="${monoStyle}">${t}</li>`)
            .join("");

        document.getElementById("csDecisions").innerHTML = p.decisions
            .map((d) => `<li style="${monoStyle}">${d}</li>`)
            .join("");

        const actions = [];
        if (p.playStoreUrl) {
            actions.push(
                `<a href="${p.playStoreUrl}" target="_blank">Play Store</a>`,
            );
        }
        document.getElementById("csActions").innerHTML = actions.join("");

        const overlay = document.getElementById("caseStudyOverlay");
        overlay.classList.add("open");
        document.body.style.overflow = "hidden";
    };
    function openCaseStudy(id) {
        const p = caseStudies[id];
        if (!p) return;

        document.getElementById("csTag").textContent = p.tag;
        document.getElementById("csTitle").textContent = p.title;
        document.getElementById("csStory").innerHTML = p.story;
        document.getElementById("csHighlight").innerHTML = p.highlight;

        document.getElementById("csTech").innerHTML = p.techStack
            .map((t) => `<li>${t}</li>`)
            .join("");

        document.getElementById("csDecisions").innerHTML = p.decisions
            .map((d) => `<li>${d}</li>`)
            .join("");

        document.getElementById("csActions").innerHTML = p.playStoreUrl
            ? `<a href="${p.playStoreUrl}" target="_blank" class="cs-btn">Play Store</a>`
            : "";

        document.getElementById("caseStudyOverlay").classList.add("open");
        document.body.style.overflow = "hidden";
    }

    function closeCaseStudy() {
        document.getElementById("caseStudyOverlay").classList.remove("open");
        document.body.style.overflow = "";
    }

    function handleOverlayClick(e) {
        if (e.target === document.getElementById("caseStudyOverlay"))
            closeCaseStudy();
    }

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeCaseStudy();
    });
</script>
